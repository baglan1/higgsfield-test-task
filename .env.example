# LLM provider selection: openai | anthropic | ollama
MEMORY_LLM_PROVIDER=openai

# Chat model (extraction + judge + optional rerank)
# OpenAI: gpt-4o-mini | gpt-4o
# Anthropic: claude-haiku-4-5 | claude-sonnet-4-6
# Ollama: llama3.1 | qwen2.5
MEMORY_CHAT_MODEL=gpt-4o-mini

# Embedding model + dimension (must agree)
# OpenAI text-embedding-3-small = 1536
# OpenAI text-embedding-3-large = 3072
# Ollama nomic-embed-text = 768
MEMORY_EMBED_MODEL=text-embedding-3-large
MEMORY_EMBED_DIM=1536

# Optional bearer auth. If unset, all endpoints (except /health) are open.
MEMORY_AUTH_TOKEN=

# Off by default. Set to 1 to enable cross-encoder LLM rerank in /recall.
MEMORY_RERANK=0

# Provider credentials (only the chosen provider's value is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434
